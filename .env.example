# Copia este fichero a `.env` y rellena los valores. NO subir `.env` al repo.

# Contraseña del usuario 'sa' de SQL Server (fuerte: mayúsculas, minúsculas,
# números y símbolos; mínimo 8 caracteres).
SA_PASSWORD=Cambia_Esta_Clave_123!

# Clave de firma de los JWT (mínimo 32 caracteres aleatorios).
# Genera una, p. ej.: openssl rand -base64 48
JWT_SIGNING_KEY=pon-aqui-una-clave-larga-y-aleatoria-de-32+caracteres

# Origen (dominio) de la app web que consumirá el API (para CORS).
WEB_ORIGIN=http://localhost:5173

# Copia este fichero a `.env` y rellena los valores. NO subir `.env` al repo.

# Contraseña del usuario 'postgres' del PostgreSQL local de docker-compose (fuerte:
# mayúsculas, minúsculas, números y símbolos). Solo para desarrollo local; en
# producción la BD es Neon y la cadena va por ConnectionStrings__DefaultConnection.
POSTGRES_PASSWORD=Cambia_Esta_Clave_123!

# Clave de firma de los JWT (mínimo 32 caracteres aleatorios).
# Genera una, p. ej.: openssl rand -base64 48
JWT_SIGNING_KEY=pon-aqui-una-clave-larga-y-aleatoria-de-32+caracteres

# Origen (dominio) de la app web que consumirá el API (para CORS).
WEB_ORIGIN=http://localhost:5173

# Token ÚNICO de la API de Clash of Clans (developer.clashofclans.com). Lo usa el
# proxy del servidor para todos los clientes; el usuario final nunca lo ve.
COC_API_TOKEN=pega-aqui-el-token-de-coc
# true = salir por el proxy de RoyaleAPI (autoriza la IP 45.79.218.79 en el token).
# false = llamar directo a CoC (autoriza la IP pública del servidor en el token).
COC_USE_PROXY=true

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "_comment": "PostgreSQL local (docker-compose levanta uno en localhost:5432). En producción (Render) se inyecta la cadena de Neon por env ConnectionStrings__DefaultConnection, con SSL Mode=Require.",
    "DefaultConnection": "Host=localhost;Port=5432;Database=clashplanner;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "ClashPlanner",
    "Audience": "ClashPlanner",
    "SigningKey": "dev-only-clashplanner-signing-key-change-me-32+chars-0123456789",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Coc": {
    "UseProxy": true
  }
}
